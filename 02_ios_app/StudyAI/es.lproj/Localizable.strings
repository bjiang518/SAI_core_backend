// Help Center
"helpCenter.subtitle" = "Encuentra respuestas a las preguntas más comunes";
"helpCenter.faq1.question" = "¿Cómo uso el calificador de tareas?";
"helpCenter.faq1.answer" = "Toma una foto de tu tarea o sube una imagen. Nuestra IA la analizará, detectará las preguntas y proporcionará retroalimentación detallada con correcciones y explicaciones.";
"helpCenter.faq2.question" = "¿Qué materias son compatibles?";
"helpCenter.faq2.answer" = "StudyAI es compatible con Matemáticas, Física, Química, Biología, Inglés, Historia, Geografía e Informática. ¡Constantemente añadimos más materias\!";
"helpCenter.faq3.question" = "¿Cómo cambio la voz de la IA?";
"helpCenter.faq3.answer" = "Ve a Configuración > Compañeros de estudio > Selecciona tu compañero. Puedes elegir entre Adam (voz masculina) y Eva (voz femenina), y personalizar la velocidad y el volumen.";
"helpCenter.faq4.question" = "¿Puedo revisar mis errores pasados?";
"helpCenter.faq4.answer" = "¡Sí\! Usa la función Revisión de errores desde la pantalla de inicio para volver a las preguntas que fallaste y practicar problemas similares.";
"helpCenter.faq5.question" = "¿Cómo funciona el sistema de rachas?";
"helpCenter.faq5.answer" = "Tu racha aumenta cada día que completas al menos una sesión de estudio. ¡Mantén tu racha para desbloquear logros y recompensas\!";
"helpCenter.faq6.question" = "¿Mis datos están seguros?";
"helpCenter.faq6.answer" = "¡Sí\! Tus datos son procesados por proveedores de IA de confianza (OpenAI, Google Gemini) únicamente para ofrecer las funciones de tutoría, y nunca se venden ni se usan para publicidad.";
"helpCenter.faq7.question" = "¿Cómo hago seguimiento de mi progreso?";
"helpCenter.faq7.answer" = "Visita la pestaña Progreso para ver estadísticas detalladas, tendencias de precisión, rendimiento por materia y patrones de aprendizaje semanal.";
"helpCenter.faq8.question" = "¿Cuál es la diferencia entre el análisis Detallado y el Rápido?";
"helpCenter.faq8.answer" = "El modo Detallado proporciona un análisis más preciso con estructura jerárquica y relaciones padre-hijo. El modo Rápido es más ágil pero más simple. Usa Detallado para tareas complejas.";
